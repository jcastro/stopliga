# Preferred backend selector. Legacy aliases still work:
# STOPLIGA_ROUTER_TYPE and STOPLIGA_CONTROLLER.
STOPLIGA_BACKEND=unifi

# Shared controller connection settings for UniFi and Omada.
STOPLIGA_CONTROLLER_HOST=10.0.1.1
# STOPLIGA_CONTROLLER_PORT=443
STOPLIGA_SITE=default
STOPLIGA_CONTROLLER_VERIFY_TLS=false
# STOPLIGA_CONTROLLER_CA_FILE=/path/to/ca.pem

# UniFi-specific authentication.
UNIFI_API_KEY=replace-me

# Omada Open API settings.
# Uncomment these when STOPLIGA_BACKEND=omada.
# STOPLIGA_CONTROLLER_HOST=omada-controller.example
# STOPLIGA_CONTROLLER_PORT=8043
# STOPLIGA_SITE=Default
# STOPLIGA_CONTROLLER_VERIFY_TLS=true
# OMADA_CLIENT_ID=replace-me
# OMADA_CLIENT_SECRET=replace-me
# OMADA_CONTROLLER_ID=replace-me
# OMADA_TARGET_TYPE=vpn
# OMADA_TARGET=WG Main
# OMADA_SOURCE_NETWORKS=LAN,IoT
# OMADA_GROUP_SIZE=16

# OPNsense settings.
# Uncomment these when STOPLIGA_BACKEND=opnsense.
# Legacy compatibility: STOPLIGA_FIREWALL_BACKEND=opnsense is also accepted.
# OPNSENSE_HOST=fw.example.local
# OPNSENSE_API_KEY=replace-me
# OPNSENSE_API_SECRET=replace-me
# OPNSENSE_VERIFY_TLS=true
# OPNSENSE_ALIAS_NAME=StopLiga

# Legacy connection aliases still work:
# UniFi: UNIFI_HOST / UNIFI_PORT / UNIFI_SITE / UNIFI_VERIFY_TLS / UNIFI_CA_FILE
# Omada: OMADA_HOST / OMADA_PORT / OMADA_SITE / OMADA_VERIFY_TLS / OMADA_CA_FILE
# Omada auth: STOPLIGA_OMADA_* and OMADA_* are both accepted

# Run mode for the container. Use "loop" for normal operation.
STOPLIGA_RUN_MODE=loop

# How often StopLiga runs a full sync, in seconds.
STOPLIGA_SYNC_INTERVAL_SECONDS=300

# Exact managed route or rule name that StopLiga should control.
STOPLIGA_ROUTE_NAME=StopLiga

# Safety limit for HTTP response size, in bytes.
# Leave the default unless you know you need to change it.
STOPLIGA_MAX_RESPONSE_BYTES=2097152

# Optional feed overrides.
# The default status source uses hayahora.futbol DNS for live block detection.
# STOPLIGA_STATUS_URL=dns://blocked.dns.hayahora.futbol
# STOPLIGA_IP_LIST_URL=https://raw.githubusercontent.com/r4y7s/laliga-ip-list/main/laliga_ip_list.txt

# Optional Gotify notifications.
# STOPLIGA_GOTIFY_URL=https://gotify.example.com
# STOPLIGA_GOTIFY_TOKEN=replace-me
# STOPLIGA_GOTIFY_PRIORITY=5
# STOPLIGA_GOTIFY_ALLOW_PLAIN_HTTP=false
# STOPLIGA_GOTIFY_VERIFY_TLS=true

# Optional Telegram notifications.
# STOPLIGA_TELEGRAM_BOT_TOKEN=123456:replace-me
# STOPLIGA_TELEGRAM_CHAT_ID=123456789
# STOPLIGA_TELEGRAM_GROUP_ID=-1001234567890
# STOPLIGA_TELEGRAM_TOPIC_ID=42
