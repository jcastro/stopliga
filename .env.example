# StopLiga starter .env
#
# 1. Copy this file to .env
# 2. Set STOPLIGA_BACKEND
# 3. Fill only the section for your router
# 4. Run: docker compose up -d
#
# Most users only need this file.

# -----------------------------------------------------------------------------
# Common settings
# -----------------------------------------------------------------------------

# Router to use: unifi, omada, fritzbox, opnsense
STOPLIGA_BACKEND=unifi

# Normal Docker use should stay in loop mode.
STOPLIGA_RUN_MODE=loop

# Check interval in seconds.
STOPLIGA_SYNC_INTERVAL_SECONDS=300

# Name of the managed route or rule.
STOPLIGA_ROUTE_NAME=StopLiga

# -----------------------------------------------------------------------------
# Shared controller settings for UniFi, Omada and FRITZ!Box
# -----------------------------------------------------------------------------

# Use these for UniFi, Omada or FRITZ!Box.
STOPLIGA_CONTROLLER_HOST=10.0.1.1
STOPLIGA_SITE=default
STOPLIGA_CONTROLLER_VERIFY_TLS=false

# Optional shared settings:
# STOPLIGA_CONTROLLER_PORT=443
# STOPLIGA_CONTROLLER_CA_FILE=/config/ca.pem

# -----------------------------------------------------------------------------
# UniFi
# -----------------------------------------------------------------------------

# Use this section only if STOPLIGA_BACKEND=unifi.
UNIFI_API_KEY=replace-me

# Optional secret-file alternative:
# UNIFI_API_KEY_FILE=/run/secrets/unifi_api_key

# Optional UniFi-only bootstrap helpers:
# STOPLIGA_VPN_NAME=Mullvad DE
# STOPLIGA_TARGETS=AA:BB:CC:DD:EE:FF,Living Room Apple TV

# -----------------------------------------------------------------------------
# Omada
# -----------------------------------------------------------------------------

# Use this section only if STOPLIGA_BACKEND=omada.
#
# Example shared controller values for Omada:
# STOPLIGA_CONTROLLER_HOST=omada-controller.example
# STOPLIGA_CONTROLLER_PORT=8043
# STOPLIGA_SITE=Default
# STOPLIGA_CONTROLLER_VERIFY_TLS=true
#
# Required Omada values:
# OMADA_CLIENT_ID=replace-me
# OMADA_CLIENT_SECRET=replace-me
# OMADA_CONTROLLER_ID=replace-me
# OMADA_TARGET_TYPE=vpn
# OMADA_TARGET=WG Main
#
# Optional Omada settings:
# OMADA_CLIENT_SECRET_FILE=/run/secrets/omada_client_secret
# OMADA_SOURCE_NETWORKS=LAN,IoT
# OMADA_GROUP_SIZE=16
# STOPLIGA_OMADA_BASE_URL=https://omada-controller.example:8043

# -----------------------------------------------------------------------------
# FRITZ!Box
# -----------------------------------------------------------------------------

# Use this section only if STOPLIGA_BACKEND=fritzbox.
#
# Example shared controller values for FRITZ!Box:
# STOPLIGA_CONTROLLER_HOST=fritz.box
# STOPLIGA_CONTROLLER_PORT=49443
# STOPLIGA_CONTROLLER_VERIFY_TLS=true
#
# Required FRITZ!Box values:
# FRITZBOX_USERNAME=stopliga
# FRITZBOX_PASSWORD=replace-me
# FRITZBOX_GATEWAY=192.168.178.2
#
# Optional FRITZ!Box settings:
# FRITZBOX_PASSWORD_FILE=/run/secrets/fritzbox_password
# FRITZBOX_ROUTE_METRIC=4096
#
# Important:
# Pick a unique FRITZBOX_ROUTE_METRIC. TR-064 routes do not support comments or labels,
# so StopLiga identifies its managed route set by gateway + metric.

# -----------------------------------------------------------------------------
# OPNsense
# -----------------------------------------------------------------------------

# Use this section only if STOPLIGA_BACKEND=opnsense.
#
# OPNSENSE_HOST=fw.example.local
# OPNSENSE_API_KEY=replace-me
# OPNSENSE_API_SECRET=replace-me
# OPNSENSE_VERIFY_TLS=true
#
# Optional OPNsense settings:
# OPNSENSE_API_KEY_FILE=/run/secrets/opnsense_api_key
# OPNSENSE_API_SECRET_FILE=/run/secrets/opnsense_api_secret
# OPNSENSE_ALIAS_NAME=StopLiga

# -----------------------------------------------------------------------------
# Optional feed overrides
# -----------------------------------------------------------------------------

# Most users can ignore this section.
#
# STOPLIGA_STATUS_URL=dns://blocked.dns.hayahora.futbol
# STOPLIGA_IP_LIST_URL=https://raw.githubusercontent.com/r4y7s/laliga-ip-list/main/laliga_ip_list.txt
# STOPLIGA_REQUEST_TIMEOUT=15
# STOPLIGA_RETRIES=4
# STOPLIGA_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional notifications
# -----------------------------------------------------------------------------

# Gotify
# STOPLIGA_GOTIFY_URL=https://gotify.example.com
# STOPLIGA_GOTIFY_TOKEN=replace-me
# STOPLIGA_GOTIFY_TOKEN_FILE=/run/secrets/gotify_token

# Telegram
# Set either STOPLIGA_TELEGRAM_CHAT_ID or STOPLIGA_TELEGRAM_GROUP_ID.
# STOPLIGA_TELEGRAM_BOT_TOKEN=123456:replace-me
# STOPLIGA_TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
# STOPLIGA_TELEGRAM_CHAT_ID=123456789
# STOPLIGA_TELEGRAM_GROUP_ID=-1001234567890
# STOPLIGA_TELEGRAM_TOPIC_ID=42
