# For most setups, edit only UNIFI_HOST and UNIFI_API_KEY.
# Leave the other values as they are.

# UniFi host or IP address.
UNIFI_HOST=10.0.1.1

# Local UniFi API key.
UNIFI_API_KEY=replace-me

# UniFi site name. "default" is the normal value.
UNIFI_SITE=default

# Set to false only if your UniFi uses a self-signed certificate.
UNIFI_VERIFY_TLS=false

# Run mode for the container. Use "loop" for normal operation.
STOPLIGA_RUN_MODE=loop

# How often StopLiga runs a full sync, in seconds.
STOPLIGA_SYNC_INTERVAL_SECONDS=300

# Exact UniFi policy route name that StopLiga should manage or create automatically.
STOPLIGA_ROUTE_NAME=StopLiga

# Safety limit for HTTP response size, in bytes.
# Leave the default unless you know you need to change it.
STOPLIGA_MAX_RESPONSE_BYTES=2097152

# Optional Gotify notifications.
# STOPLIGA_GOTIFY_URL=https://gotify.example.com
# STOPLIGA_GOTIFY_TOKEN=replace-me
# STOPLIGA_GOTIFY_PRIORITY=5
# STOPLIGA_GOTIFY_ALLOW_PLAIN_HTTP=false
# STOPLIGA_GOTIFY_VERIFY_TLS=true

# Optional Telegram notifications.
# STOPLIGA_TELEGRAM_BOT_TOKEN=123456:replace-me
# STOPLIGA_TELEGRAM_CHAT_ID=123456789
# STOPLIGA_TELEGRAM_GROUP_ID=-1001234567890
# STOPLIGA_TELEGRAM_TOPIC_ID=42

# Optional web UI. Set STOPLIGA_WEBUI_ENABLED=true and expose port 8080 to use it.
# STOPLIGA_WEBUI_ENABLED=false
# STOPLIGA_WEBUI_PORT=8080
# STOPLIGA_WEBUI_HOST=0.0.0.0
