# Required
UNIFI_HOST=192.168.1.1
# Choose one auth method:
# UNIFI_API_KEY=replace-me
# UNIFI_API_KEY_FILE=/run/secrets/unifi_api_key
UNIFI_USERNAME=admin
UNIFI_PASSWORD=change-me
# UNIFI_USERNAME_FILE=/run/secrets/unifi_username
# UNIFI_PASSWORD_FILE=/run/secrets/unifi_password

# Optional but recommended for plug-and-play route creation
STOPLIGA_VPN_NAME=Mullvad DE
STOPLIGA_TARGETS=apple-tv,ps5,aa:bb:cc:dd:ee:ff

# Optional
UNIFI_SITE=default
UNIFI_VERIFY_TLS=true
# UNIFI_CA_FILE=/certs/unifi-ca.pem

STOPLIGA_RUN_MODE=loop
STOPLIGA_SYNC_INTERVAL_SECONDS=300
STOPLIGA_ROUTE_NAME=StopLiga
STOPLIGA_LOG_LEVEL=INFO
STOPLIGA_DRY_RUN=false

# Advanced
STOPLIGA_STATUS_URL=https://raw.githubusercontent.com/r4y7s/laliga-ip-list/main/laliga_status.json
STOPLIGA_IP_LIST_URL=https://raw.githubusercontent.com/r4y7s/laliga-ip-list/main/laliga_ip_list.txt
STOPLIGA_ENABLE_WHEN_BLOCKED=true
STOPLIGA_INVALID_ENTRY_POLICY=fail
STOPLIGA_MAX_DESTINATIONS=2048
STOPLIGA_REQUEST_TIMEOUT=15
STOPLIGA_RETRIES=4
STOPLIGA_STATE_FILE=/data/state.json
STOPLIGA_BOOTSTRAP_GUARD_FILE=/data/bootstrap_guard.json
STOPLIGA_LOCK_FILE=/data/stopliga.lock
STOPLIGA_HEALTH_MAX_AGE_SECONDS=
STOPLIGA_DESTINATION_FIELD=auto
STOPLIGA_DUMP_PAYLOADS_ON_ERROR=false
STOPLIGA_FEED_ALLOW_PRIVATE_HOSTS=false
STOPLIGA_STRICT_FEED_CONSISTENCY=true
# Optional container UID/GID remap for Linux hosts
STOPLIGA_UID=1000
STOPLIGA_GID=1000
